---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const now = new Date();
const posts = (await getCollection('blog', ({ data }) =>
	!data.draft && data.pubDate <= now
)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`블로그 — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.blog-header {
				border-bottom: 1px solid #e8e8e8;
				padding: 3em 0 2em;
				margin-bottom: 2em;
			}
			.blog-header h1 {
				font-size: 1.8em;
				font-weight: 800;
				margin: 0 0 0.3em;
				letter-spacing: -0.03em;
			}
			.blog-header p {
				margin: 0;
				color: #888;
				font-size: 0.95em;
			}
			.post-count {
				font-size: 0.78em;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #999;
				margin: 0 0 1em;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				border-bottom: 1px solid #eee;
			}
			ul li:first-child {
				border-top: 1px solid #eee;
			}
			ul li a {
				display: flex;
				align-items: center;
				gap: 1.2em;
				padding: 1em 0;
				text-decoration: none;
				color: inherit;
				transition: opacity 0.15s;
			}
			ul li a:hover { opacity: 0.72; }
			ul li a:hover .title {
				text-decoration: underline;
				text-underline-offset: 3px;
			}
			.thumb {
				width: 72px;
				height: 72px;
				object-fit: cover;
				border-radius: 6px;
				flex-shrink: 0;
				background: #eee;
			}
			.thumb-placeholder {
				width: 72px;
				height: 72px;
				border-radius: 6px;
				flex-shrink: 0;
				background: #eee;
			}
			.meta { flex: 1; min-width: 0; }
			.title {
				margin: 0 0 0.3em;
				font-size: 1em;
				font-weight: 600;
				color: #222;
				line-height: 1.4;
			}
			.date {
				margin: 0;
				font-size: 0.82em;
				color: #aaa;
			}
			.empty {
				padding: 4em 0;
				text-align: center;
				color: #bbb;
				font-size: 0.95em;
				line-height: 1.8;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-header">
				<h1>식재료 이야기</h1>
				<p>보관법, 제철식재료, 손질법, 효능까지 — 식탁을 바꾸는 식재료 정보</p>
			</div>

			{posts.length === 0 ? (
				<p class="empty">아직 작성된 글이 없습니다.<br/>곧 유익한 식재료 정보로 찾아오겠습니다.</p>
			) : (
				<>
					<p class="post-count">전체 {posts.length}편</p>
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage
										? <img class="thumb" src={post.data.heroImage} alt={post.data.title} />
										: <div class="thumb-placeholder" />
									}
									<div class="meta">
										<p class="title">{post.data.title}</p>
										<p class="date"><FormattedDate date={post.data.pubDate} /></p>
									</div>
								</a>
							</li>
						))}
					</ul>
				</>
			)}
		</main>
		<Footer />
	</body>
</html>
