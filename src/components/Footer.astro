---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="copyright">&copy; {today.getFullYear()} 식재료 이야기. All rights reserved.</p>
		<p class="tagline">재료를 알면 밥상이 바뀝니다</p>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em;
		background: #111;
		color: #888;
		text-align: center;
	}
	.footer-inner {
		max-width: 720px;
		margin: 0 auto;
	}
	.copyright {
		margin: 0 0 0.3em 0;
		font-size: 0.85em;
		color: #666;
	}
	.tagline {
		margin: 0;
		font-size: 0.8em;
		color: #555;
		letter-spacing: 0.05em;
	}
</style>
